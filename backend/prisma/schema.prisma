generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  emailVerified    Boolean   @default(false) @map("email_verified")
  passwordHash     String?   @map("password_hash")
  fullNameEnc      String    @map("full_name_enc") // AES-256-GCM encrypted
  dateOfBirthEnc   String?   @map("date_of_birth_enc") // AES-256-GCM encrypted
  avatarUrl        String?   @map("avatar_url")
  mfaEnabled       Boolean   @default(false) @map("mfa_enabled")
  mfaSecretEnc     String?   @map("mfa_secret_enc") // AES-256-GCM encrypted TOTP secret
  mfaBackupHashes  String    @default("") @map("mfa_backup_hashes") // JSON array of Argon2 hashed backup codes
  accountLocked    Boolean   @default(false) @map("account_locked")
  lockExpiresAt    DateTime? @map("lock_expires_at")
  failedLoginCount Int       @default(0) @map("failed_login_count")
  consentVersion   String?   @map("consent_version")
  consentAt        DateTime? @map("consent_at")
  referralSource   String?   @map("referral_source")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")
  measurementSystem String   @default("metric") @map("measurement_system") // "metric" or "imperial"

  sessions                Session[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  goals                   Goal[]
  profiles                Profile[]
  auditLogs               AuditLog[]
  oauthAccounts           OAuthAccount[]

  @@map("users")
}

model OAuthAccount {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  provider   String
  providerId String   @map("provider_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@map("oauth_accounts")
}

model Session {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  refreshTokenHash  String   @map("refresh_token_hash")
  deviceFingerprint String?  @map("device_fingerprint")
  ipAddress         String?  @map("ip_address")
  userAgent         String?  @map("user_agent")
  createdAt         DateTime @default(now()) @map("created_at")
  expiresAt         DateTime @map("expires_at")
  revoked           Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model Profile {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  intakeResponses IntakeResponse[]
  goals           Goal[]

  @@index([userId])
  @@map("profiles")
}

model Goal {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  profileId  String   @map("profile_id")
  goalType   String   @map("goal_type")
  extrasEnc  String?  @map("extras_enc") // AES-256-GCM encrypted JSON for goal-specifics
  selectedAt DateTime @default(now()) @map("selected_at")

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile          Profile           @relation(fields: [profileId], references: [id], onDelete: Cascade)
  nutritionPlans   NutritionPlan[]

  @@index([userId])
  @@map("goals")
}

model IntakeResponse {
  id           String   @id @default(uuid())
  profileId    String   @map("profile_id")
  section      String
  responsesEnc String   @map("responses_enc") // AES-256-GCM encrypted JSONB
  completedAt  DateTime @default(now()) @map("completed_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("intake_responses")
}

model NutritionPlan {
  id               String    @id @default(uuid())
  goalId           String    @map("goal_id")
  planVersion      Int       @default(1) @map("plan_version")
  generationParams Json?     @map("generation_params")
  generationStatus String    @default("complete") @map("generation_status") // generating | complete | failed
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  expiresAt        DateTime? @map("expires_at")

  goal    Goal         @relation(fields: [goalId], references: [id], onDelete: Cascade)
  modules PlanModule[]

  @@index([goalId])
  @@map("nutrition_plans")
}

model PlanModule {
  id                  String    @id @default(uuid())
  planId              String    @map("plan_id")
  moduleType          String    @map("module_type")
  moduleData          Json      @map("module_data")
  generatedAt         DateTime  @default(now()) @map("generated_at")
  regeneratedCount    Int       @default(0) @map("regenerated_count")
  generationStartedAt DateTime? @map("generation_started_at")
  generationMs        Int?      @map("generation_ms")

  plan         NutritionPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  mealFeedback MealFeedback[]

  @@index([planId])
  @@map("plan_modules")
}

model MealFeedback {
  id        String   @id @default(uuid())
  moduleId  String   @map("module_id")
  dayIndex  Int      @map("day_index")
  mealType  String   @map("meal_type")
  feedback  String?
  createdAt DateTime @default(now()) @map("created_at")

  module PlanModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@map("meal_feedback")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  eventType String   @map("event_type")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
  @@map("audit_log")
}
