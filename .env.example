# Environment
NODE_ENV=development

# Server
PORT=4000
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://nutribot:nutribot_dev_password@localhost:5432/nutribot?schema=public

# Redis
REDIS_URL=redis://:nutribot_redis_dev@localhost:6379

# JWT (RS256)
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_ISSUER=nutribot
JWT_AUDIENCE=nutribot-app

# Encryption (AES-256-GCM) — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Anthropic Claude API
ANTHROPIC_API_KEY=

# Email (SendGrid placeholder — currently console-logged)
EMAIL_PROVIDER=console
SENDGRID_API_KEY=
EMAIL_FROM=noreply@nutribot.app

# OAuth (Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# OAuth (Apple)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# reCAPTCHA (simulated in dev)
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Rate Limiting
RATE_LIMIT_ENABLED=true
